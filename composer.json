{
    "name": "blendbyte/livewire-honeypot",
    "description": "Honeypot + time-trap spam protection for Livewire 4 forms. No CAPTCHAs, no external requests.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Blendbyte\\LivewireHoneypot\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blendbyte\\LivewireHoneypot\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Blendbyte\\LivewireHoneypot\\HoneypotServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.5",
        "laravel/framework": "^13.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "pestphp/pest-plugin-livewire": "^4.0",
        "larastan/larastan": "^3.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --ansi --memory-limit=512M"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
